{
  "document_type": "Акт",
  "document_type_display": "Акт выполненных работ / оказанных услуг",
  "description": "Документ, подтверждающий выполнение работ или оказание услуг",
  
  "fields": {
    "header": {
      "title": "Реквизиты документа",
      "fields": [
        {
          "name": "Номер документа",
          "key": "номер",
          "type": "string",
          "required": true,
          "pattern": "^[0-9]+$",
          "label": "№"
        },
        {
          "name": "Дата документа",
          "key": "дата",
          "type": "date",
          "required": true,
          "format": "DD MMMM YYYY",
          "label": "от"
        },
        {
          "name": "Место составления",
          "key": "место",
          "type": "string",
          "required": false
        }
      ]
    },
    "basis": {
      "title": "Основание",
      "fields": [
        {
          "name": "Основание",
          "key": "основание",
          "type": "string",
          "required": false,
          "format": "Договор № от DD.MM.YYYY"
        }
      ]
    },
    "provider": {
      "title": "Продавец",
      "fields": [
        {
          "name": "Продавец",
          "key": "исполнитель",
          "type": "string",
          "required": true,
          "validation": "org_name"
        },
        {
          "name": "ИНН продавца",
          "key": "инн_исполнителя",
          "type": "number",
          "required": false,
          "length": 10,
          "validation": "inn"
        }
      ]
    },
    "customer": {
      "title": "Покупатель",
      "fields": [
        {
          "name": "Покупатель",
          "key": "заказчик",
          "type": "string",
          "required": true,
          "validation": "org_name"
        },
        {
          "name": "ИНН покупателя",
          "key": "инн_заказчика",
          "type": "number",
          "required": false,
          "length": 10,
          "validation": "inn"
        }
      ]
    }
  },

  "table": {
    "enabled": true,
    "title": "Перечень выполненных работ / оказанных услуг",
    "columns": [
      {
        "name": "№",
        "key": "num",
        "width": 5,
        "align": "center"
      },
      {
        "name": "Наименование работ/услуг",
        "key": "наименование",
        "width": 35
      },
      {
        "name": "Ед. изм.",
        "key": "единица",
        "width": 10,
        "align": "center"
      },
      {
        "name": "Кол-во",
        "key": "количество",
        "width": 10,
        "align": "center"
      },
      {
        "name": "Цена",
        "key": "цена",
        "width": 12,
        "align": "right"
      },
      {
        "name": "Сумма",
        "key": "сумма",
        "width": 12,
        "align": "right"
      }
    ]
  },

  "footer": {
    "title": "Итоги",
    "fields": [
      {
        "name": "Итого",
        "key": "итого",
        "type": "currency",
        "required": true
      },
      {
        "name": "НДС",
        "key": "ндс",
        "type": "currency",
        "required": false
      },
      {
        "name": "Всего",
        "key": "всего",
        "type": "currency",
        "required": true
      }
    ]
  },

  "acceptance": {
    "enabled": true,
    "title": "Сдача-приёмка",
    "description": "Работы выполнены в полном объёме, в установленные сроки и с надлежащим качеством. Акт составлен в 2 экземплярах.",
    "signatories": [
      {
        "name": "Исполнитель",
        "key": "исполнитель_подпись",
        "position": "Директор ООО «Поставщик»"
      },
      {
        "name": "Заказчик",
        "key": "заказчик_подпись",
        "position": "Директор ООО «Покупатель»"
      }
    ]
  },

  "signatures": {
    "enabled": true,
    "signatories": [
      {
        "name": "Руководитель исполнителя",
        "key": "руководитель",
        "position": "Директор"
      },
      {
        "name": "Главный бухгалтер исполнителя",
        "key": "главный_бухгалтер",
        "position": "Главный бухгалтер"
      }
    ]
  },

  "styling": {
    "theme": "classic",
    "show_logo": true,
    "show_qr_code": false,
    "watermark": false
  }
}
